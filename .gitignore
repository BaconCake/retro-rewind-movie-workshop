# =============================================================================
# Retro Rewind Movie Workshop — .gitignore
# =============================================================================
# Repo holds:  the Python source, the README, LICENSE, build spec/scripts,
#              the GitHub Actions workflow, and any reference docs.
# Everything else listed below is local — generated at runtime, downloaded
# separately, or specific to one developer's machine. None of it should
# ever land in a commit.
# =============================================================================

# ── User data created by the tool at runtime ────────────────────────────
# These hold the user's custom movies, settings, sort prefs, etc. They live
# next to the exe in production; ignoring them here means a developer can
# safely run the tool from inside their cloned repo without polluting commits.
config.json
custom_slots.json
nr_custom_slots.json
replacements.json
title_changes.json
base_slot_edits.json
edited_slots.json
shipped_slots.json
sort_preferences.json

# ── Backups created by the tool ─────────────────────────────────────────
*.json.bak

# ── Generated runtime folders ───────────────────────────────────────────
Output/
layout_cache/
_pak_cache/

# ── Generated images and runtime caches ─────────────────────────────────
# The tool creates layout previews, thumbnails, and asset PNGs at runtime.
# Real assets that ship with the repo (if any) should be placed in a
# specifically-named folder (e.g. assets/) and added back via a "!" rule.
*.png
*.jpg
*.jpeg
*.webp

# ── PyInstaller build artifacts ─────────────────────────────────────────
build/
dist/
*.spec.bak

# ── Python build cache ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Third-party tools (downloaded by users / CI, not source) ────────────
tools/repak.exe
tools/texconv.exe
repak.exe
texconv.exe

# ── Personal launcher (each dev has their own) ──────────────────────────
run_workshop.bat

# ── IDE / OS junk ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# ── Virtual environments ────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Logs ────────────────────────────────────────────────────────────────
*.log